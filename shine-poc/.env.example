# GitHub
VITE_GITHUB_TOKEN=your_github_token
VITE_GITHUB_ORG=esimplicityinc

# SharePoint / Microsoft Graph (get from IT)
VITE_MS_CLIENT_ID=your_azure_app_client_id
VITE_MS_TENANT_ID=your_azure_tenant_id
VITE_MS_CLIENT_SECRET=your_azure_app_client_secret

# Jira Cloud (get from https://id.atlassian.com/manage-profile/security/api-tokens)
VITE_JIRA_EMAIL=your_atlassian_email@example.com
VITE_JIRA_API_TOKEN=your_jira_api_token
VITE_JIRA_BASE_URL=https://esimplicity.atlassian.net

# Confluence Cloud (uses same Atlassian credentials as Jira)
VITE_CONFLUENCE_BASE_URL=https://esimplicity.atlassian.net/wiki

# Anthropic Claude API (for conversational responses)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
